datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

model Topic {
  id        String   @id @default(uuid())
  name      String
  elo       Int      @default(1000)
  createdAt DateTime @default(now())
  materials String
  history   String   @default("[]")
  preferences String   @default("{\"explanationStyle\":\"practical\",\"tone\":\"casual\",\"exampleStyle\":\"real_world\"}")
}

model Preference {
  id               String @id @default("default")
  explanationStyle String @default("practical")
  tone             String @default("casual")
  exampleStyle     String @default("real_world")
}